$procs = Get-WmiObject Win32_Process -Filter "Name = 'python.exe'"
foreach ($proc in $procs) {
    if ($proc.CommandLine -like "*uvicorn*" -and $proc.CommandLine -like "*main:app*") {
        $procId = $proc.ProcessId
        $start = (Get-Process -Id $procId -ErrorAction SilentlyContinue).StartTime
        Write-Host "uvicorn PID=$procId started=$start"
        Write-Host "  CMD: $($proc.CommandLine)"
        if ($proc.CommandLine -notlike "*CollectCore*") {
            Write-Host "  *** KILLING (not CollectCore venv) ***"
            Stop-Process -Id $procId -Force -ErrorAction SilentlyContinue
        }
    }
}
Write-Host "Done. Remaining uvicorn on port 8001:"
netstat -ano | Select-String ":8001.*LISTEN"

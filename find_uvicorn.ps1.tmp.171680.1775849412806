# Kill all old multiprocessing uvicorn workers (all but the ones from today's session, parent 109932)
$procs = Get-WmiObject Win32_Process -Filter "Name = 'python.exe'"
$keepParents = @(109932)  # today's reloader (already killed but child may persist)

Write-Host "=== Killing old uvicorn workers ==="
foreach ($proc in $procs) {
    $parentPid = [int]($proc.CommandLine -replace '.*parent_pid=(\d+).*', '$1')
    if ($proc.CommandLine -like "*multiprocessing*" -and $keepParents -notcontains $parentPid) {
        $procId = $proc.ProcessId
        $mem = [math]::Round((Get-Process -Id $procId -ErrorAction SilentlyContinue).WorkingSet64 / 1MB, 1)
        Write-Host "Killing PID=$procId (mem=${mem}MB, parent=$parentPid)"
        Stop-Process -Id $procId -Force -ErrorAction SilentlyContinue
    }
}

Start-Sleep -Seconds 1
Write-Host "`n=== Remaining Python processes ==="
Get-WmiObject Win32_Process -Filter "Name = 'python.exe'" | ForEach-Object {
    $procId = $_.ProcessId
    $mem = [math]::Round((Get-Process -Id $procId -ErrorAction SilentlyContinue).WorkingSet64 / 1MB, 1)
    Write-Host "PID=$procId mem=${mem}MB"
}

timeout /t 2 /nobreak >nul
start "CollectCore Backend" powershell -NoExit -Command "Set-Location -Path 'F:\Dropbox\Apps\CollectCore\backend'; & '.\.venv\Scripts\python.exe' -m uvicorn main:app --reload --port 8001"

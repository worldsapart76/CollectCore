# Python virtualenv + cache
backend/.venv/
__pycache__/
*.pyc

# Node dependencies
frontend/node_modules/

# Local app data (do NOT commit). Path-anchored with leading slash so the
# rule only matches the project-root copies. backend/data/mobile_seed.db
# IS committed — it's the production seed bundled into the Railway deploy.
/images/
/data/
/exports/

# API keys and secrets (never commit)
backend/.env

# OS junk
.DS_Store
Thumbs.db

# Vite dev server cache
*.timestamp-*.mjs

# Dropbox sync artifacts
*.tmp
*.tmp.*
.dropbox
.dropbox.cache/
*(conflicted copy *)

# Claude Code harness internals (session lock, scheduled-task state, etc.)
.claude/

# Capacitor Android scaffold — only present on the indefinitely-deferred
# `mobile-shell` branch; ignored on main so branch switches don't keep
# re-flagging it as untracked.
frontend/android/

# Local DB snapshots dumped into docs/ during ad-hoc backup work
docs/collectcore_backup_*.zip

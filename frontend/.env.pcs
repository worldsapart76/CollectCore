# Authenticated guest tier (/pcs/) build.
# VITE_IS_ADMIN=false  -> reuse the non-admin UI gating (hide admin controls).
# VITE_IS_PCS=true      -> select the server-data adapter (src/pcs/pcsData.js),
#                          the /pcs write modals, and skip the guest WASM
#                          bootstrap. See docs/guest_cloud_accounts_plan.md.
VITE_IS_ADMIN=false
VITE_IS_PCS=true
VITE_API_BASE_URL=https://api.collectcoreapp.com
VITE_ENABLED_MODULES=photocards

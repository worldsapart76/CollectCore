@import '@fontsource-variable/inter';

:root {
  font-family: 'Inter Variable', 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
  font-synthesis: none;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

a {
  font-weight: 500;
  color: var(--green);
  text-decoration: inherit;
}

a:hover {
  color: var(--green-vivid);
}

html, body {
  height: 100%;
  overflow: hidden;
}

body {
  margin: 0;
  min-width: 320px;
}

h1 {
  font-size: 3.2em;
  line-height: 1.1;
}

button {
  border-radius: 6px;
  border: 1px solid transparent;
  font-size: 1em;
  font-weight: 500;
  font-family: inherit;
  cursor: pointer;
  transition: background 0.15s ease, border-color 0.15s ease;
}

button:focus,
button:focus-visible {
  outline: 2px solid var(--green-vivid);
  outline-offset: 2px;
}

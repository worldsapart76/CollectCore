def upsert_author(conn, name: str) -> int:
    name = name.strip()
    row = conn.execute(
        "SELECT author_id FROM lkup_book_authors WHERE author_name = ?", (name,)
    ).fetchone()
    if row:
        return row[0]
    cur = conn.execute("INSERT INTO lkup_book_authors (author_name) VALUES (?)", (name,))
    return cur.lastrowid


def upsert_series(conn, name: str) -> int:
    name = name.strip()
    row = conn.execute(
        "SELECT series_id FROM tbl_book_series WHERE series_name = ?", (name,)
    ).fetchone()
    if row:
        return row[0]
    cur = conn.execute("INSERT INTO tbl_book_series (series_name) VALUES (?)", (name,))
    return cur.lastrowid


def upsert_tag(conn, name: str) -> int:
    name = name.strip().lower()
    row = conn.execute(
        "SELECT tag_id FROM lkup_book_tags WHERE tag_name = ?", (name,)
    ).fetchone()
    if row:
        return row[0]
    cur = conn.execute("INSERT INTO lkup_book_tags (tag_name) VALUES (?)", (name,))
    return cur.lastrowid


def make_title_sort(title: str) -> str:
    lower = title.lower()
    for prefix in ("the ", "a ", "an "):
        if lower.startswith(prefix):
            return title[len(prefix):]
    return title


def is_duplicate(conn, title: str, primary_author_name: str) -> bool:
    row = conn.execute(
        """
        SELECT bd.item_id
        FROM tbl_book_details bd
        JOIN xref_book_item_authors xia ON xia.item_id = bd.item_id AND xia.author_order = 1
        JOIN lkup_book_authors a ON a.author_id = xia.author_id
        WHERE lower(bd.title) = lower(?) AND lower(a.author_name) = lower(?)
        """,
        (title, primary_author_name),
    ).fetchone()
    return row is not None


def insert_book(conn, row_data: dict, ids: dict, verbose: bool) -> str:
    """
    Insert one Goodreads row into the DB.
    Returns "imported", "skipped", or "flagged:<reason>".
    """
    raw_title = row_data.get("Title", "").strip()
    if not raw_title:
        return "flagged:empty_title"

    clean_title, series_name, series_number = parse_series_from_title(raw_title)

    primary_author_raw = row_data.get("Author", "").strip()
    additional_raw = row_data.get("Additional Authors", "").strip()

    if not primary_author_raw:
        return "flagged:no_author"

    all_author_names = [primary_author_raw]
    if additional_raw:
        all_author_names += [a.strip() for a in additional_raw.split(",") if a.strip()]
    # Deduplicate while preserving order (same name can appear in both Author and Additional Authors)
    seen = set()
    deduped = []
    for name in all_author_names:
        key = name.lower()
        if key not in seen:
            seen.add(key)
            deduped.append(name)
    all_author_names = deduped

    # Duplicate check
    if is_duplicate(conn, clean_title, primary_author_raw):
        return "skipped"

    # Shelves
    bookshelves_raw = row_data.get("Bookshelves", "")
    exclusive_shelf = row_data.get("Exclusive Shelf", "").strip().lower()
    shelves = parse_shelves(bookshelves_raw)
    classified = classify_shelves(shelves)

    ownership_status_id = resolve_ownership(classified, exclusive_shelf, ids)
    reading_status_id = resolve_reading_status(classified, exclusive_shelf, ids)
    top_level_category_id = resolve_top_level_category(classified, ids)
    age_level_id = ids["age_levels"].get(classified["age_level_name"]) if classified["age_level_name"] else None

    date_added = row_data.get("Date Added", "").strip() or None
    date_read_raw = row_data.get("Date Read", "").strip() or None

    my_rating_raw = row_data.get("My Rating", "0").strip()
    try:
        star_rating = float(my_rating_raw)
        if star_rating == 0:
            star_rating = None
    except ValueError:
        star_rating = None

    review = row_data.get("My Review", "").strip() or None

    flag_reason = None
    if not classified["format_entries"] and exclusive_shelf == "read":
        flag_reason = "read_without_library_tag"

    # --- Insert tbl_items ---
    if date_added:
        cur = conn.execute(
            """INSERT INTO tbl_items
               (collection_type_id, top_level_category_id, ownership_status_id,
                reading_status_id, date_read, created_at)
               VALUES (?, ?, ?, ?, ?, ?)""",
            (ids["book_collection_type_id"], top_level_category_id, ownership_status_id,
             reading_status_id, date_read_raw, date_added),
        )
    else:
        cur = conn.execute(
            """INSERT INTO tbl_items
               (collection_type_id, top_level_category_id, ownership_status_id,
                reading_status_id, date_read)
               VALUES (?, ?, ?, ?, ?)""",
            (ids["book_collection_type_id"], top_level_category_id, ownership_status_id,
             reading_status_id, date_read_raw),
        )
    item_id = cur.lastrowid

    # --- Insert tbl_book_details ---
    conn.execute(
        """INSERT INTO tbl_book_details
           (item_id, title, title_sort, age_level_id, star_rating, review)
           VALUES (?, ?, ?, ?, ?, ?)""",
        (item_id, clean_title, make_title_sort(clean_title), age_level_id, star_rating, review),
    )

    # --- Authors ---
    for order, aname in enumerate(all_author_names, start=1):
        author_id = upsert_author(conn, aname)
        conn.execute(
            "INSERT INTO xref_book_item_authors (item_id, author_id, author_order) VALUES (?, ?, ?)",
            (item_id, author_id, order),
        )

    # --- Series ---
    if series_name:
        series_id = upsert_series(conn, series_name)
        conn.execute(
            "INSERT OR IGNORE INTO xref_book_item_series (item_id, series_id, series_number) VALUES (?, ?, ?)",
            (item_id, series_id, series_number),
        )

    # --- Copies (one per format) ---
    publisher = row_data.get("Publisher", "").strip() or None
    page_count_raw = row_data.get("Number of Pages", "").strip()
    try:
        page_count = int(page_count_raw) if page_count_raw else None
    except ValueError:
        page_count = None
    year_published = row_data.get("Year Published", "").strip() or None

    format_entries = classified["format_entries"]
    for (fmt_id, _ownership_str, _extra_tag) in format_entries:
        conn.execute(
            """INSERT INTO tbl_book_copies
               (item_id, format_detail_id, publisher, page_count, published_date)
               VALUES (?, ?, ?, ?, ?)""",
            (item_id, fmt_id, publisher, page_count, year_published),
        )

    # --- Tags ---
    freeform_tags = list(dict.fromkeys(classified["freeform_tags"]))  # dedupe, preserve order
    if classified["dnf_tags"]:
        for dt in classified["dnf_tags"]:
            if dt not in freeform_tags:
                freeform_tags.append(dt)
    for tag_name in freeform_tags:
        tag_id = upsert_tag(conn, tag_name)
        conn.execute(
            "INSERT OR IGNORE INTO xref_book_item_tags (item_id, tag_id) VALUES (?, ?)",
            (item_id, tag_id),
        )

    # --- Genres ---
    seen_genres = set()
    for (genre_name, subgenre_name) in classified["genre_entries"]:
        genre_id = ids["genres"].get(genre_name)
        if not genre_id:
            continue
        sub_genre_id = ids["subgenres"].get((genre_name, subgenre_name)) if subgenre_name else None
        key = (genre_id, sub_genre_id)
        if key in seen_genres:
            continue
        seen_genres.add(key)
        conn.execute(
            "INSERT OR IGNORE INTO xref_book_item_genres (item_id, top_level_genre_id, sub_genre_id) VALUES (?, ?, ?)",
            (item_id, genre_id, sub_genre_id),
        )

    if verbose:
        print(f"  Imported: {clean_title} -- {primary_author_raw}")

    if flag_reason:
        return f"flagged:{flag_reason}"
    return "imported"


# ---------------------------------------------------------------------------
# Dry-run: tag inventory
# ---------------------------------------------------------------------------

def classify_tag_for_display(tag: str) -> str:
    if tag in READING_STATUS_TAGS or tag in DNF_TAGS:
        return "reading-status"
    if tag in TAG_ONLY_TAGS:
        return "tag-only"
    if tag in NON_FICTION_TAGS:
        cat = "non-fiction-indicator"
        if tag in GENRE_MAP:
            cat += " + genre"
        return cat
    if tag == "new-adult":
        return "age-level: New Adult"
    if tag.startswith("ya-"):
        suffix = tag[3:]
        if suffix in YA_GENRE_SUFFIX_MAP:
            g, s = YA_GENRE_SUFFIX_MAP[suffix]
            sub = f" / {s}" if s else ""
            return f"age-level: YA + genre: {g}{sub}"
        return "age-level: YA + genre: UNMAPPED (freeform)"
    if tag in FORMAT_TAG_MAP:
        return "format"
    if tag.startswith("library-"):
        return "format (unknown library-*)"
    if tag in GENRE_MAP:
        g, s = GENRE_MAP[tag]
        sub = f" / {s}" if s else ""
        return f"genre: {g}{sub}"
    return "-> FREEFORM"


def run_dry_run(csv_path: Path):
    tag_counter: Counter = Counter()
    exclusive_shelf_counter: Counter = Counter()
    total_rows = 0
    missing_title = 0
    missing_author = 0

    with open(csv_path, newline="", encoding="utf-8-sig") as f:
        reader = csv.DictReader(f)
        for row in reader:
            total_rows += 1
            if not row.get("Title", "").strip():
                missing_title += 1
            if not row.get("Author", "").strip():
                missing_author += 1

            exclusive_shelf_counter[row.get("Exclusive Shelf", "").strip().lower()] += 1

            for tag in parse_shelves(row.get("Bookshelves", "")):
                tag_counter[tag] += 1

    print(f"\n{'='*60}")
    print(f"DRY RUN -- {csv_path.name}")
    print(f"{'='*60}")
    print(f"\nTotal rows:     {total_rows:,}")
    print(f"Missing title:  {missing_title}")
    print(f"Missing author: {missing_author}")

    print(f"\n--- Exclusive Shelf distribution ---")
    for shelf, count in exclusive_shelf_counter.most_common():
        print(f"  {count:>6,}  {shelf}")

    print(f"\n--- All shelf tags (by frequency) ---")
    print(f"  {'Count':>6}  {'Tag':<45}  Classification")
    print(f"  {'------':>6}  {'-'*45}  {'-'*40}")
    for tag, count in tag_counter.most_common():
        category = classify_tag_for_display(tag)
        line = f"  {count:>6,}  {tag:<45}  {category}"
        print(line.encode("ascii", "replace").decode("ascii"))

    print(f"\n--- Genre map: {len(GENRE_MAP)} direct mappings ---")
    for tag, (genre, subgenre) in sorted(GENRE_MAP.items()):
        sub = f" / {subgenre}" if subgenre else ""
        print(f"  {tag:<40}  {genre}{sub}")

    print(f"\n--- YA genre suffix map: {len(YA_GENRE_SUFFIX_MAP)} mappings ---")
    for suffix, (genre, subgenre) in sorted(YA_GENRE_SUFFIX_MAP.items()):
        sub = f" / {subgenre}" if subgenre else ""
        print(f"  ya-{suffix:<37}  YA + {genre}{sub}")

    print(f"\n{'='*60}")
    print("Review tags above, then run without --dry-run to import.")
    print(f"{'='*60}\n")



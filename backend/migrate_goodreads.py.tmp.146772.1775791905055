    "suspense":        ("Crime", "Suspense/Thriller"),
    "suspense-mystery":("Crime", "Mystery"),  # combined tag; Mystery is alphabetically first
}

# ---------------------------------------------------------------------------
# Known status / format / tag-only shelf tags
# ---------------------------------------------------------------------------

READING_STATUS_TAGS = {"to-read", "currently-reading", "read"}
DNF_TAGS = {"dnf-permanent", "dnf-read-later"}

FORMAT_TAG_MAP = {
    "library-hardback":         (1, "Owned", None),
    "library-hardcover":        (1, "Owned", None),
    "library-paper":            (2, "Owned", None),
    "library-kindle":           (4, "Owned", None),
    "library-kobo":             (5, "Owned", None),
    "library-audible":          (7, "Owned", None),
    "library-kindle-unlimited": (4, "Borrowed", "kindle-unlimited"),
    "library-overdrive":        (6, "Borrowed", "overdrive"),
    "library-smashwords":       (6, "Owned", "smashwords"),
    "library-glose":            (6, "Owned", "glose"),
    "library-free-online":      (6, "Owned", "free-online"),
    "library-audio-file":       (8, "Owned", "audio-file"),
    "library-audiocd":          (8, "Owned", "audiocd"),
    "library-kobo-audio":       (8, "Owned", "kobo-audio"),
    "library-chirp":            (8, "Owned", "chirp"),
    "library-other":            (6, "Owned", "other"),
    "library-formerly-owned":   (None, "Formerly Owned", None),
}

TAG_ONLY_TAGS = {"freebie", "stripped-or-arc", "advanced-reader-copy"}

# Tags that force top_level_category_id = Non-Fiction.
# "writing-and-moviemaking" matches actual Goodreads export spelling.
NON_FICTION_TAGS = {
    "biography", "gaming", "non-fiction",
    "writing-and-movie-making", "writing-and-moviemaking",
}

SERIES_RE = re.compile(r"^(.+?)\s*\((.+?),\s*#([\d.]+)\)\s*$")

# ---------------------------------------------------------------------------
# DB helpers
# ---------------------------------------------------------------------------

def get_columns(conn, table_name):
    rows = conn.execute(f"PRAGMA table_info({table_name})").fetchall()
    return {row[1] for row in rows}


def ensure_date_read_column(conn):
    cols = get_columns(conn, "tbl_items")
    if "date_read" not in cols:
        conn.execute("ALTER TABLE tbl_items ADD COLUMN date_read TEXT")
        print("  Added date_read column to tbl_items")


def load_lookup_ids(conn):
    """Return dicts mapping names/codes to IDs for all needed lookups."""
    ids = {}

    # collection_type_id for books
    row = conn.execute(
        "SELECT collection_type_id FROM lkup_collection_types WHERE collection_type_code = 'book'"
    ).fetchone()
    if not row:
        sys.exit("ERROR: book collection type not found in DB. Run migrate_books_schema.py first.")
    ids["book_collection_type_id"] = row[0]

    # top_level_category_id: Fiction, Non-Fiction (scoped to book collection type)
    cats = conn.execute(
        "SELECT category_name, top_level_category_id FROM lkup_top_level_categories WHERE collection_type_id = ?",
        (ids["book_collection_type_id"],),
    ).fetchall()
    ids["top_level_categories"] = {name: cid for name, cid in cats}
    if "Fiction" not in ids["top_level_categories"] or "Non-Fiction" not in ids["top_level_categories"]:
        sys.exit("ERROR: Fiction/Non-Fiction top-level categories not found. Run migrate_books_schema.py first.")

    # ownership_status_id
    rows = conn.execute("SELECT status_name, ownership_status_id FROM lkup_ownership_statuses").fetchall()
    ids["ownership"] = {name: oid for name, oid in rows}

    # reading_status_id
    rows = conn.execute("SELECT status_name, read_status_id FROM lkup_book_read_statuses").fetchall()
    ids["read_status"] = {name: sid for name, sid in rows}

    # genre IDs: top_level_genre_id keyed by genre_name
    rows = conn.execute(
        "SELECT genre_name, top_level_genre_id FROM lkup_book_top_level_genres"
    ).fetchall()
    ids["genres"] = {name: gid for name, gid in rows}

    # sub-genre IDs: keyed by (genre_name, sub_genre_name) to handle duplicate names
    rows = conn.execute(
        """
        SELECT g.genre_name, s.sub_genre_name, s.sub_genre_id
        FROM lkup_book_sub_genres s
        JOIN lkup_book_top_level_genres g ON g.top_level_genre_id = s.top_level_genre_id
        """
    ).fetchall()
    ids["subgenres"] = {(gname, sname): sid for gname, sname, sid in rows}

    # age level IDs
    rows = conn.execute("SELECT age_level_name, age_level_id FROM lkup_book_age_levels").fetchall()
    ids["age_levels"] = {name: aid for name, aid in rows}

    return ids



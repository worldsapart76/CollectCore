def run_migration(csv_path: Path, db_path: Path, verbose: bool):
    print(f"\nConnecting to DB: {db_path}")
    if not db_path.exists():
        sys.exit(f"ERROR: DB not found at {db_path}")

    conn = sqlite3.connect(db_path)
    conn.execute("PRAGMA foreign_keys = ON")

    print("Ensuring date_read column exists...")
    ensure_date_read_column(conn)

    print("Loading lookup IDs...")
    ids = load_lookup_ids(conn)

    counts = {"imported": 0, "skipped": 0, "flagged": 0, "errors": 0, "total": 0}
    flagged_rows = []
    error_rows = []

    with open(csv_path, newline="", encoding="utf-8-sig") as f:
        reader = csv.DictReader(f)
        for row in reader:
            counts["total"] += 1
            try:
                result = insert_book(conn, row, ids, verbose)
            except Exception as e:
                counts["errors"] += 1
                error_rows.append((row.get("Title", "?"), str(e)))
                conn.rollback()
                continue

            if result == "imported":
                counts["imported"] += 1
            elif result == "skipped":
                counts["skipped"] += 1
            elif result.startswith("flagged:"):
                counts["flagged"] += 1
                flagged_rows.append((row.get("Title", "?"), result))
            conn.commit()

    conn.close()

    print(f"\n{'='*50}")
    print("Goodreads migration complete")
    print(f"  Imported:  {counts['imported']:>6,}")
    print(f"  Skipped:   {counts['skipped']:>6,}  (duplicate title+author)")
    print(f"  Flagged:   {counts['flagged']:>6,}  (ambiguous ownership, read-without-library-tag, etc.)")
    print(f"  Errors:    {counts['errors']:>6,}")
    print(f"  Total rows:{counts['total']:>6,}")
    print(f"{'='*50}")

    if flagged_rows:
        print(f"\nFlagged titles ({len(flagged_rows)}):")
        for title, reason in flagged_rows[:30]:
            print(f"  [{reason}] {title}".encode("ascii", "replace").decode("ascii"))
        if len(flagged_rows) > 30:
            print(f"  ... and {len(flagged_rows) - 30} more")

    if error_rows:
        print(f"\nErrors ({len(error_rows)}):")
        for title, err in error_rows[:20]:
            print(f"  {title}: {err}".encode("ascii", "replace").decode("ascii"))


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Migrate Goodreads CSV export to CollectCore")
    parser.add_argument("csv_path", nargs="?", default=str(DEFAULT_CSV), help="Path to Goodreads CSV export")
    parser.add_argument("--db", default=str(DEFAULT_DB), help="Path to CollectCore SQLite DB")
    parser.add_argument("--dry-run", action="store_true", help="Parse only; print tag inventory; no DB writes")
    parser.add_argument("--verbose", action="store_true", help="Print each imported title")
    args = parser.parse_args()

    csv_path = Path(args.csv_path).expanduser()
    db_path = Path(args.db).expanduser()

    if not csv_path.exists():
        sys.exit(f"ERROR: CSV not found at {csv_path}")

    if args.dry_run:
        run_dry_run(csv_path)
    else:
        run_migration(csv_path, db_path, args.verbose)

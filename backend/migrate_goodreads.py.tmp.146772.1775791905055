def parse_shelves(bookshelves_raw: str) -> list[str]:
    return [s.strip().lower() for s in bookshelves_raw.split(",") if s.strip()]


def parse_series_from_title(raw_title: str):
    """Returns (clean_title, series_name_or_None, series_number_or_None)."""
    m = SERIES_RE.match(raw_title.strip())
    if m:
        try:
            series_num = float(m.group(3))
        except ValueError:
            series_num = None  # e.g. "0.2.1" — store without series number
        return m.group(1).strip(), m.group(2).strip(), series_num
    return raw_title.strip(), None, None


def classify_shelves(shelves: list[str]):
    """
    Returns a dict with classified shelf info:
      reading_status_tag, dnf_tags, format_entries, ownership_override,
      non_fiction, age_level_name, freeform_tags, genre_entries
    """
    result = {
        "reading_status_tag": None,
        "dnf_tags": [],
        "format_entries": [],    # list of (format_detail_id, ownership_str, extra_tag_or_None)
        "ownership_override": None,
        "non_fiction": False,
        "age_level_name": None,  # "Young Adult", "New Adult", etc.
        "freeform_tags": [],
        "genre_entries": [],     # list of (genre_name, subgenre_name_or_None)
    }

    for tag in shelves:
        # Reading status
        if tag in READING_STATUS_TAGS:
            if result["reading_status_tag"] is None:
                result["reading_status_tag"] = tag
            continue

        # DNF
        if tag in DNF_TAGS:
            result["dnf_tags"].append(tag)
            continue

        # Tag-only (no format or genre effect)
        if tag in TAG_ONLY_TAGS:
            result["freeform_tags"].append(tag)
            continue

        # Non-Fiction indicators
        if tag in NON_FICTION_TAGS:
            result["non_fiction"] = True
            # Check for genre mapping too (e.g. biography -> Biography genre)
            if tag in GENRE_MAP:
                result["genre_entries"].append(GENRE_MAP[tag])
            else:
                result["freeform_tags"].append(tag)
            continue

        # New Adult age level
        if tag == "new-adult":
            result["age_level_name"] = "New Adult"
            continue

        # YA prefix: ya-{suffix} -> age_level=Young Adult + genre from suffix
        if tag.startswith("ya-"):
            result["age_level_name"] = "Young Adult"
            suffix = tag[3:]
            if suffix in YA_GENRE_SUFFIX_MAP:
                result["genre_entries"].append(YA_GENRE_SUFFIX_MAP[suffix])
            else:
                result["freeform_tags"].append(tag)
            continue

        # Known format tags
        if tag in FORMAT_TAG_MAP:
            fmt_id, ownership_str, extra_tag = FORMAT_TAG_MAP[tag]
            if tag == "library-formerly-owned":
                result["ownership_override"] = "Formerly Owned"
            else:
                result["format_entries"].append((fmt_id, ownership_str, extra_tag))
                if extra_tag:
                    result["freeform_tags"].append(extra_tag)
            continue

        # Unknown library-* tags
        if tag.startswith("library-"):
            stripped = tag[len("library-"):]
            result["format_entries"].append((6, "Owned", stripped))
            result["freeform_tags"].append(stripped)
            continue

        # Genre map
        if tag in GENRE_MAP:
            result["genre_entries"].append(GENRE_MAP[tag])
            continue

        # Everything else -> freeform
        result["freeform_tags"].append(tag)

    return result


def resolve_ownership(classified, exclusive_shelf: str, ids: dict) -> int:
    if classified["ownership_override"] == "Formerly Owned":
        oid = ids["ownership"].get("Formerly Owned")
        if oid:
            return oid

    format_entries = classified["format_entries"]
    if format_entries:
        has_owned = any(e[1] == "Owned" for e in format_entries)
        if has_owned:
            return ids["ownership"]["Owned"]
        return ids["ownership"].get("Borrowed", ids["ownership"]["Owned"])

    if exclusive_shelf in ("to-read", "currently-reading"):
        return ids["ownership"].get("Wanted", ids["ownership"]["Owned"])
    if exclusive_shelf == "read":
        return ids["ownership"]["Owned"]

    return ids["ownership"].get("Pending", ids["ownership"]["Owned"])


def resolve_reading_status(classified, exclusive_shelf: str, ids: dict):
    if classified["dnf_tags"]:
        return ids["read_status"].get("DNF")

    shelf = exclusive_shelf or classified["reading_status_tag"] or ""
    if shelf == "read":
        return ids["read_status"].get("Read")
    if shelf in ("currently-reading", "to-read"):
        return ids["read_status"].get("Want to Read")

    return None


def resolve_top_level_category(classified, ids: dict) -> int:
    if classified["non_fiction"]:
        return ids["top_level_categories"]["Non-Fiction"]
    return ids["top_level_categories"]["Fiction"]



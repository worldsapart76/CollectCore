        item_result = db.execute(
            text("""
                INSERT INTO tbl_items (
                    collection_type_id,
                    top_level_category_id,
                    ownership_status_id,
                    notes
                )
                VALUES (
                    :collection_type_id,
                    :top_level_category_id,
                    :ownership_status_id,

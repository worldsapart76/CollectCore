# CollectCore Backend — Environment Variables
# Copy this file to .env and fill in your API keys.

# External API keys (optional — features degrade gracefully without them)
COMIC_VINE_API_KEY=
GOOGLE_BOOKS_API_KEY=
RAWG_API_KEY=
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=
TMDB_API_KEY=
TMDB_READ_ACCESS_TOKEN=
BGG_API_KEY=

# Data directory override (optional — defaults to project root)
# When set, the SQLite DB lives at $COLLECTCORE_DATA_DIR/data/collectcore.db
# and images live under $COLLECTCORE_DATA_DIR/images/.
# On Railway, set this to the volume mount point (e.g. /data).
# COLLECTCORE_DATA_DIR=

# CORS allowed origins (comma-separated, defaults to http://localhost:5181)
# On Railway, include the deployed domain AND any desktop/mobile origins.
# Example: https://collectcore.up.railway.app,http://localhost:5181
# CORS_ORIGINS=http://localhost:5181

# Cloudflare R2 (Catalog image hosting for guest mobile app)
# Fill these in to publish the Catalog to R2 via tools/publish_catalog.py.
# Endpoint: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Public base URL for catalog images. No trailing slash.
# Either R2 dev URL (https://pub-xxxxxx.r2.dev) or a Cloudflare custom domain.
R2_PUBLIC_BASE_URL=

# Railway deployment notes
# ------------------------
# Required Railway service env vars (set in Service → Variables):
#   COLLECTCORE_DATA_DIR=/data            # mount a Railway Volume at /data
#   CORS_ORIGINS=https://<railway-url>,http://localhost:5181
#   R2_*                                   # all five R2 vars above
#   <external API keys above>              # whichever you use
# Service settings:
#   Root Directory: backend
#   Start Command:  (empty — Procfile provides it)
#   Volume:         mount path /data (size 1 GB is plenty)
